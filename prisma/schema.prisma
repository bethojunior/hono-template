// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  PENDING
  PUBLISHED
  PROCESSING
  PROCESSED
  FAILED_PUBLISH
  FAILED_PROCESSING
  DEAD_LETTER
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  password     String
  resourceId   String?
  refreshToken String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  
  resource  Resource? @relation(fields: [resourceId], references: [id])

  @@map("users")
}

model Event {
  id          String      @id @default(uuid())
  type        String
  aggregateId String?
  status      EventStatus @default(PENDING)
  payload     Json

  failedReason String?
  attempts     Int       @default(0)
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([aggregateId])
  @@index([status, nextRetryAt])
  @@map("events")
}

model Resource {
  id  String  @id @default(cuid())
  url String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("resource")
}

model Blog {
  id      String @id @default(cuid())
  title   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blogs")
}
